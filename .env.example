# ──────────────────────────────────────────────────────────────────
# VERCEL PRODUCTION — set these in Vercel Project Settings → Environment
# Variables. Do NOT commit these to git.
# ──────────────────────────────────────────────────────────────────
#
# DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require&pgbouncer=true&connection_limit=1"
# NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"
# NEXTAUTH_SECRET="<32-byte base64 — generate with: openssl rand -base64 32>"
# NEXTAUTH_URL="https://your-project.vercel.app"
# ADMIN_EMAIL="you@example.com"
# ADMIN_PASSWORD="a strong unique password"
# ADMIN_NAME="Your Name"
# RESEND_API_KEY="re_..."           (optional)
# NEXT_PUBLIC_GA_ID="G-XXXXXXX"     (optional)
