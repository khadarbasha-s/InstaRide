// Postgres version of the FastRental schema — used for Vercel deployment.
// Copy this over prisma/schema.prisma when deploying to switch providers.
//
//   cp prisma/schema.postgres.prisma prisma/schema.prisma
//   pnpm prisma generate
//   pnpm prisma db push
//   pnpm db:seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Schema is otherwise identical to the SQLite version.
// String columns for role / category / transmission / fuelType / status / source
// are kept (instead of enums) so the model code stays the same across both DBs.
// "featuresJson" and "tagsJson" remain as JSON-encoded strings to avoid
// array-type differences between SQLite and Postgres.

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model City {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  isActive   Boolean    @default(true)
  heroImage  String?
  seoTitle   String?
  seoDesc    String?
  seoContent String?
  locations  Location[]
  cars       Car[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  cityId    String
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  heroImage String?
  seoTitle  String?
  seoDesc   String?
  content   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cityId, slug])
  @@index([slug])
}

model Car {
  id             String     @id @default(cuid())
  slug           String     @unique
  cityId         String?
  city           City?      @relation(fields: [cityId], references: [id], onDelete: SetNull)
  name           String
  brand          String
  model          String
  category       String
  transmission   String
  fuelType       String
  seats          Int
  mileage        Float
  engineCC       Int?
  driveType      String?
  pricePerDay    Int
  minBookingDays Int        @default(2)
  unlimitedKm    Boolean    @default(true)
  isAvailable    Boolean    @default(true)
  isFeatured     Boolean    @default(false)
  sortOrder      Int        @default(0)
  shortDesc      String
  longDesc       String
  featuresJson   String     @default("[]")
  rentalTerms    String
  rating         Float      @default(4.8)
  reviewsCount   Int        @default(0)
  images         CarImage[]
  leads          Lead[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([category])
  @@index([brand])
  @@index([cityId])
  @@index([isAvailable, isFeatured])
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([carId])
}

model Lead {
  id           String    @id @default(cuid())
  name         String
  phone        String
  email        String?
  pickupDate   DateTime?
  returnDate   DateTime?
  carId        String?
  car          Car?      @relation(fields: [carId], references: [id], onDelete: SetNull)
  locationName String?
  message      String?
  source       String    @default("CONTACT_FORM")
  status       String    @default("NEW")
  notes        String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([carId])
}

model Blog {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String
  coverImage  String
  authorName  String    @default("FastRental Team")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  seoTitle    String?
  seoDesc     String?
  tagsJson    String    @default("[]")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isPublished, publishedAt])
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, sortOrder])
}
